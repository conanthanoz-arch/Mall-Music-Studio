\f1\b0\fs32 \AppleTypeServices\AppleTypeServicesF2293774 \cf0 \
To build this programmatically, you can use 
\f2\b \AppleTypeServices\AppleTypeServicesF2293774 Pillow (PIL)
\f1\b0 \AppleTypeServices\AppleTypeServicesF2293774 , Python's standard library for image processing. It is fast, highly stable, and completely free.\
The code below establishes the basic framework for your 6-hour video generation pipeline. It stacks a fixed background, calculates the guard's walking position, applies a dynamic color tint based on the time of day, and saves the final output as sequential frames.\
\pard\pardeftab560\sa80\partightenfactor0

\f0\b\fs42 \AppleTypeServices\AppleTypeServicesF2293774 \cf0 The Python Frame-Generator Script\
\pard\pardeftab560\slleading40\partightenfactor0

\f3\b0\fs28\fsmilli14118 \AppleTypeServices \cf0 import os\
import math\
from PIL import Image, ImageEnhance\
\
\pard\pardeftab560\slleading40\partightenfactor0

\f4\i \cf0 # 1. SETUP CONSTANTS & DIRECTORIES
\f3\i0 \
FRAME_RATE = 30\
TOTAL_FRAMES = 60 * 60 * 6 * FRAME_RATE  
\f4\i # 6 hours at 30fps = 648,000 frames
\f3\i0 \
OUTPUT_DIR = "rendered_frames"\
os.makedirs(OUTPUT_DIR, exist_ok=True)\
\

\f4\i # 2. LOAD ASSETS (Ensure assets are the same resolution, e.g., 1920x1080)
\f3\i0 \

\f4\i # Make sure your character and foreground assets are saved as transparent PNGs
\f3\i0 \
bg_base = Image.open("mall_background.png").convert("RGBA")\
guard_right = Image.open("guard_walk_right.png").convert("RGBA")\
guard_left = Image.open("guard_walk_left.png").convert("RGBA")\
foreground = Image.open("mall_pillars.png").convert("RGBA")\
\

\f4\i # Initial positioning variables
\f3\i0 \
guard_x = 100\
guard_y = 500  
\f4\i # Floor level (perpendicular alignment)
\f3\i0 \
guard_speed = 2\
direction = "right"\
\

\f4\i # 3. CORE RENDERING LOOP
\f3\i0 \

\f4\i # For testing, you can change TOTAL_FRAMES to 300 (10 seconds) to verify the output
\f3\i0 \
for frame in range(TOTAL_FRAMES):\
    \
    
\f4\i # --- PHASE A: UPDATE GUARD PATROL LOGIC ---
\f3\i0 \
    if direction == "right":\
        guard_x += guard_speed\
        current_guard_sprite = guard_right\
        if guard_x > 1500:  
\f4\i # Right boundary of the mall screen
\f3\i0 \
            direction = "left"\
    else:\
        guard_x -= guard_speed\
        current_guard_sprite = guard_left\
        if guard_x < 100:   
\f4\i # Left boundary of the mall screen
\f3\i0 \
            direction = "right"\
\
    
\f4\i # --- PHASE B: LAYER THE SCENE (Bottom to Top) ---
\f3\i0 \
    
\f4\i # Create a fresh canvas copy of the background for this frame
\f3\i0 \
    frame_canvas = bg_base.copy()\
    \
    
\f4\i # Paste the guard onto the background using its own alpha channel as the mask
\f3\i0 \
    frame_canvas.alpha_composite(current_guard_sprite, dest=(guard_x, guard_y))\
    \
    
\f4\i # Paste the pillars/plants over the guard to create depth
\f3\i0 \
    frame_canvas.alpha_composite(foreground, dest=(0, 0))\
\
    
\f4\i # --- PHASE C: DAY/NIGHT TIME MATHEMATICS ---
\f3\i0 \
    
\f4\i # Calculate a smooth wave (0.0 to 1.0) spanning the entire 6-hour duration
\f3\i0 \
    
\f4\i # 0.0 represents deep midnight, 1.0 represents brightest noon
\f3\i0 \
    time_factor = (math.sin(2 * math.pi * frame / TOTAL_FRAMES) + 1) / 2\
    \
    
\f4\i # Translate that math into visual color grading filters
\f3\i0 \
    brightness_multiplier = 0.3 + (time_factor * 0.7)  
\f4\i # Ranges from 0.3 (dark) to 1.0 (bright)
\f3\i0 \
    color_multiplier = 0.4 + (time_factor * 0.6)       
\f4\i # Desaturates slightly at night
\f3\i0 \
\
    
\f4\i # --- PHASE D: APPLY COLOR GRADING ---
\f3\i0 \
    
\f4\i # Convert to RGB to apply enhancements safely
\f3\i0 \
    final_frame = frame_canvas.convert("RGB")\
    \
    
\f4\i # Apply brightness drop for nighttime
\f3\i0 \
    brightness_filter = ImageEnhance.Brightness(final_frame)\
    final_frame = brightness_filter.enhance(brightness_multiplier)\
    \
    
\f4\i # Apply color adjustment (or tinting)
\f3\i0 \
    color_filter = ImageEnhance.Color(final_frame)\
    final_frame = color_filter.enhance(color_multiplier)\
    \
    
\f4\i # Night tint variation: Gently blend a dark blue layer during the night cycle
\f3\i0 \
    if time_factor < 0.5:\
        night_overlay = Image.new("RGB", final_frame.size, (10, 20, 50)) 
\f4\i # Deep midnight blue
\f3\i0 \
        blend_amount = (0.5 - time_factor) * 0.5 
\f4\i # Max 25% opacity blue blend
\f3\i0 \
        final_frame = Image.blend(final_frame, night_overlay, alpha=blend_amount)\
\
    
\f4\i # --- PHASE E: SAVE FRAME TO DISK ---
\f3\i0 \
    frame_name = f"frame_\{frame:06d\}.jpg"\
    final_frame.save(os.path.join(OUTPUT_DIR, frame_name), "JPEG", quality=90)\
\
print("Frame rendering complete.")\
\pard\pardeftab560\sa80\partightenfactor0

