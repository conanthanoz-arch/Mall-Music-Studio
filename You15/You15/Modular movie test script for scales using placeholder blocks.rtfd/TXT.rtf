\f3\fs28\fsmilli14118 \AppleTypeServices \cf0 import os\
import math\
import sys\
from PIL import Image, ImageDraw\
\
FRAME_RATE = 30\
TEST_FRAMES = 300  
\f4\i # 10 seconds of video to test the layout motion
\f3\i0 \
OUTPUT_DIR = "test_pipe"\
os.makedirs(OUTPUT_DIR, exist_ok=True)\
\
\pard\pardeftab560\slleading40\partightenfactor0

\f4\i \cf0 # 1. GENERATE PLACEHOLDER SCHEMATIC ASSETS
\f3\i0 \

\f4\i # Base Background Layer (Light gray walls, dark gray floor line at Y:850)
\f3\i0 \
bg_base = Image.new("RGBA", (1920, 1080), (220, 220, 220, 255))\
draw_bg = ImageDraw.Draw(bg_base)\
draw_bg.rectangle([0, 850, 1920, 1080], fill=(80, 80, 80, 255)) 
\f4\i # The Floor
\f3\i0 \
\

\f4\i # Guard Sprite Layer (50x175 Pixel Silhouette Box)
\f3\i0 \

\f4\i # The sprite frame canvas itself is 1920x1080 to match coordinate mapping easily
\f3\i0 \
guard_sprite = Image.new("RGBA", (1920, 1080), (0, 0, 0, 0))\
draw_guard = ImageDraw.Draw(guard_sprite)\
draw_guard.rectangle([0, 0, 50, 175], fill=(0, 120, 255, 255)) 
\f4\i # Blue Guard Box
\f3\i0 \
\

\f4\i # Foreground Columns Layer (1920x1080 Transparent Canvas)
\f3\i0 \
foreground = Image.new("RGBA", (1920, 1080), (0, 0, 0, 0))\
draw_fg = ImageDraw.Draw(foreground)\

\f4\i # Central structural pillar dividing Store 1 and Store 2 (Width: 100px)
\f3\i0 \
draw_fg.rectangle([910, 0, 1010, 850], fill=(140, 140, 140, 255)) \
\

\f4\i # Mock Advertiser Storefront Graphics (450x350 Pixels)
\f3\i0 \
ad_1 = Image.new("RGBA", (450, 350), (255, 100, 100, 255)) 
\f4\i # Red Brand Box
\f3\i0 \
ad_2 = Image.new("RGBA", (450, 350), (100, 255, 100, 255)) 
\f4\i # Green Brand Box
\f3\i0 \
\

\f4\i # 2. RUN VELOCITY & MAPPING TEST LOOP
\f3\i0 \
guard_x = 100\
guard_y = 675  
\f4\i # 850 (Floor Line) - 175 (Guard Height) = 675 Head Coordinate
\f3\i0 \
guard_speed = 4\
direction = "right"\
\
print("--- Rendering 10-Second Layout Verification Grid ---")\
\
for frame in range(TEST_FRAMES):\
    
\f4\i # Movement logic check
\f3\i0 \
    if direction == "right":\
        guard_x += guard_speed\
        if guard_x > 1750: direction = "left"\
    else:\
        guard_x -= guard_speed\
        if guard_x < 100: direction = "right"\
        \
    
\f4\i # Stack the composition layers
\f3\i0 \
    canvas = bg_base.copy()\
    \
    
\f4\i # Drop Ads onto the wall slots
\f3\i0 \
    canvas.alpha_composite(ad_1, dest=(350, 500))\
    canvas.alpha_composite(ad_2, dest=(1120, 500))\
    \
    
\f4\i # Overlap the guard at his dynamic moving X position
\f3\i0 \
    canvas.alpha_composite(guard_sprite, dest=(guard_x, guard_y))\
    \
    
\f4\i # Layer the foreground pillar over the moving guard
\f3\i0 \
    canvas.alpha_composite(foreground, dest=(0, 0))\
    \
    
\f4\i # Save the calibration frame to disk
\f3\i0 \
    frame_name = f"test_frame_\{frame:03d\}.jpg"\
    canvas.convert("RGB").save(os.path.join(OUTPUT_DIR, frame_name), "JPEG", quality=80)\
\
print("[SUCCESS] Test compilation complete. 300 test frames written to 'test_pipe/'")\
