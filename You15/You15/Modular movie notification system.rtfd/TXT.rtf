\f0\b\fs42 \AppleTypeServices\AppleTypeServicesF2293774 \cf0 2. The Updated Auto-Recovery Script with Discord Notifications\
\pard\pardeftab560\slleading80\partightenfactor0

\f1\b0\fs32 \AppleTypeServices\AppleTypeServicesF2293774 \cf0 This updated version of your monitor script uses 
\fs28\fsmilli14118 \AppleTypeServices\AppleTypeServicesF2293774 curl
\fs32 \AppleTypeServices\AppleTypeServicesF2293774  (a standard tool installed by default on almost all computers) to send a structured notification payload directly to your Discord server the exact millisecond an error or recovery occurs.\
\pard\pardeftab560\sa80\partightenfactor0

\f0\b\fs42 \AppleTypeServices\AppleTypeServicesF2293774 \cf0 For Linux / Mac (start_stream.sh)\
\pard\pardeftab560\slleading40\partightenfactor0

\f3\i\b0\fs28\fsmilli14118 \AppleTypeServices \cf0 #!/bin/bash
\f4\i0 \
\

\f3\i # Configuration Variables
\f4\i0 \
STREAM_KEY="YOUR_YOUTUBE_STREAM_KEY"\
IMAGE_PIPE="stream_pipe/live_pipe_%03d.jpg"\
AUDIO_FILE="lofi_audio.mp3"\
LOG_FILE="stream_monitor.log"\
\

\f3\i # PASTE YOUR COPIED DISCORD WEBHOOK URL HERE
\f4\i0 \
DISCORD_URL="https://discord.com"\
\

\f3\i # Helper function to send Discord messages
\f4\i0 \
send_discord_alert() \{\
    local message="$1"\
    curl -H "Content-Type: application/json" -X POST -d "\{\\"content\\": \\"$message\\"\}" "$DISCORD_URL"\
\}\
\
echo "=== Lo-Fi Ambient Stream Monitor Started ===" | tee -a "$LOG_FILE"\
send_discord_alert "\uc0\u55357 \u56960  **Stream Server Alert**: The 24/7 Lo-Fi Stream monitor has been launched successfully at $(date)."\
\
while true\
do\
    echo "Launching FFmpeg pipeline..." | tee -a "$LOG_FILE"\
    \
    
\f3\i # Execute the streaming command
\f4\i0 \
    ffmpeg -f image2 -loop 1 -framerate 30 -pattern_type sequence -start_number 0 \\\
    -i "$IMAGE_PIPE" -stream_loop -1 -i "$AUDIO_FILE" \\\
    -c:v libx264 -pix_fmt yuv420p -preset veryfast -b:v 3000k -g 60 \\\
    -c:a aac -b:a 168k -ar 44100 -f flv "rtmp://://youtube.com" 2>> "$LOG_FILE"\
\
    
\f3\i # If the script reaches this point, FFmpeg has crashed or disconnected
\f4\i0 \
    echo "WARNING: FFmpeg disconnected or crashed. Attempting recovery..." | tee -a "$LOG_FILE"\
    \
    
\f3\i # Send an urgent alert to your phone
\f4\i0 \
    send_discord_alert "\uc0\u9888 \u65039  **STREAM CRASH DETECTED**: FFmpeg connection dropped at $(date). Attempting automatic recovery loop in 5 seconds..."\
    \
    sleep 5\
done\
\pard\pardeftab560\sa80\partightenfactor0

\f0\b\fs42 \AppleTypeServices\AppleTypeServicesF2293774 \cf0 For Windows (start_stream.bat)\
\pard\pardeftab560\slleading40\partightenfactor0

\f4\b0\fs28\fsmilli14118 \AppleTypeServices \cf0 @echo off\
set STREAM_KEY=YOUR_YOUTUBE_STREAM_KEY\
set IMAGE_PIPE=stream_pipe\\live_pipe_%%03d.jpg\
set AUDIO_FILE=lofi_audio.mp3\
set DISCORD_URL=https://discord.com\
\
echo Launching FFmpeg pipeline...\
:: Send startup notification using powershell curl wrapper\
powershell -Command "Invoke-RestMethod -Uri '%DISCORD_URL%' -Method Post -ContentType 'application/json' -Body '\{\\"content\\":\\"\uc0\u55357 \u56960  **Stream Server Alert**: Windows Stream Monitor started successfully.\\"\}'"\
\
:start\
ffmpeg -f image2 -loop 1 -framerate 30 -pattern_type sequence -start_number 0 -i "%IMAGE_PIPE%" -stream_loop -1 -i "%AUDIO_FILE%" -c:v libx264 -pix_fmt yuv420p -preset veryfast -b:v 3000k -g 60 -c:a aac -b:a 168k -ar 44100 -f flv "rtmp://://youtube.com%" 2>> stream_monitor.log\
\
echo WARNING: FFmpeg crashed. Reconnecting in 5 seconds...\
powershell -Command "Invoke-RestMethod -Uri '%DISCORD_URL%' -Method Post -ContentType 'application/json' -Body '\{\\"content\\":\\"\uc0\u9888 \u65039  **STREAM CRASH DETECTED**: Windows server lost connection to YouTube. Rebooting loop now...\\"\}'"\
\
timeout /t 5\
goto start\
\pard\pardeftab560\slleading80\partightenfactor0

