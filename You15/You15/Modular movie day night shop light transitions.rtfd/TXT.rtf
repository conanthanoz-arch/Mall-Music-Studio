\f0\b\fs42 \AppleTypeServices\AppleTypeServicesF2293774 \cf0 4. Dynamic Ad and Flashlight Integration\
\pard\pardeftab560\slleading80\partightenfactor0

\f1\b0\fs32 \AppleTypeServices\AppleTypeServicesF2293774 \cf0 To make sure your advertisers' storefronts don't look awkwardly bright in the middle of a dark, closed mall, use your 
\fs28\fsmilli14118 \AppleTypeServices\AppleTypeServicesF2293774 is_mall_open
\fs32 \AppleTypeServices\AppleTypeServicesF2293774  status variable to change how the ads are blended into the scene:\
\pard\pardeftab560\slleading40\partightenfactor0

\f4\i\fs28\fsmilli14118 \AppleTypeServices \cf0 # Fetch active brand PNG files from your spreadsheet pipeline
\f5\i0 \
ad_1, ad_2 = get_live_ads()\
\
if not is_mall_open:\
    
\f4\i # If the mall is closed, apply a heavy desaturation and brightness drop to the ads
\f5\i0 \
    
\f4\i # This simulates the store's interior display window lights clicking shut
\f5\i0 \
    ad_1 = ImageEnhance.Brightness(ad_1).enhance(0.15)\
    ad_1 = ImageEnhance.Color(ad_1).enhance(0.3)\
    ad_2 = ImageEnhance.Brightness(ad_2).enhance(0.15)\
    ad_2 = ImageEnhance.Color(ad_2).enhance(0.3)\
\

\f4\i # Stack the modified advertiser assets into their designated wall slots
\f5\i0 \
canvas_base.alpha_composite(ad_1, dest=(350, 500))\
canvas_base.alpha_composite(ad_2, dest=(1120, 500))\
\

\f4\i # Overlap your security guard sprite
\f5\i0 \
canvas_base.alpha_composite(sprite, dest=(guard_x, guard_y))\
\

\f4\i # PHASE 5: FLOATING FLASHLIGHT ILLUMINATION (Night Only)
\f5\i0 \
if not is_mall_open:\
    
\f4\i # Calculate the exact pixel offset so the flashlight beam tracks with the guard's hands
\f5\i0 \
    
\f4\i # If the guard walks right, project the light cone forward; if left, invert the mask
\f5\i0 \
    flashlight_offset_x = guard_x + (60 if direction == "right" else -250)\
    flashlight_offset_y = guard_y + 60 
\f4\i # Hand height level
\f5\i0 \
    \
    
\f4\i # Composite the light beam overlay onto the dark scene
\f5\i0 \
    canvas_base.alpha_composite(guard_flashlight_mask, dest=(flashlight_offset_x, flashlight_offset_y))\
\

\f4\i # Finish the frame by overlaying your foreground structural pillars
\f5\i0 \
canvas_base.alpha_composite(foreground, dest=(0, 0))\
