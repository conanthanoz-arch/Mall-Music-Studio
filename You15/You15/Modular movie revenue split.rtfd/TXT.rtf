\f0\b\fs42 \AppleTypeServices\AppleTypeServicesF2293774 \cf0 3. Automated Revenue Allocation Module\
\pard\pardeftab560\slleading80\partightenfactor0

\f1\b0\fs32 \AppleTypeServices\AppleTypeServicesF2293774 \cf0 Add this accounting module directly into your project directory. It parses your tracklist array and asset configurations, reads your ad platform monthly payout report, and outputs an audit sheet detailing exactly how much cash to transfer to each creative contributor.\
Save this script as 
\fs28\fsmilli14118 \AppleTypeServices\AppleTypeServicesF2293774 calculate_payouts.py
\fs32 \AppleTypeServices\AppleTypeServicesF2293774 :\
\pard\pardeftab560\slleading40\partightenfactor0

\f6\fs28\fsmilli14118 \AppleTypeServices \cf0 import csv\
\
def generate_monthly_payout_audit(monthly_ad_revenue):\
    
\f7\i # Total operational constants for a full 24-hour stream cycle
\f6\i0 \
    TOTAL_DAY_SECONDS = 24 * 60 * 60 
\f7\i # 86,400 seconds
\f6\i0 \
    \
    owner_guaranteed_share = 0.33333 * monthly_ad_revenue\
    total_art_payout = 0\
    total_music_payout = 0\
    \
    contributors = []\
    \
    print(f"=== PROCESSING DISTRIBUTION AUDIT FOR: $\{monthly_ad_revenue:,.2f\} ===")\
    \
    
\f7\i # 1. READ RAW REVENUE LEDGER
\f6\i0 \
    try:\
        with open("contributor_ledger.csv", mode="r") as file:\
            reader = csv.DictReader(file)\
            for row in reader:\
                contributors.append(row)\
    except FileNotFoundError:\
        print("[ERROR] 'contributor_ledger.csv' tracking matrix missing!")\
        return\
\
    
\f7\i # 2. RUN MATRIX SPLIT CALCULATIONS
\f6\i0 \
    print("\\n--- INDIVIDUAL PAYOUT MANIFEST ---")\
    for person in contributors:\
        name = person["Contributor_Name"]\
        asset_type = person["Asset_Type"]\
        \
        if asset_type == "music":\
            
\f7\i # Scale music: (Track Duration / 24 Hours) * 33.333% of total revenue
\f6\i0 \
            duration = float(person["Metric_Weight"].split()[0])\
            coverage_pct = duration / TOTAL_DAY_SECONDS\
            individual_payout = (coverage_pct * 0.33333) * monthly_ad_revenue\
            total_music_payout += individual_payout\
            \
        elif asset_type == "art":\
            
\f7\i # Scale art: (Hours Active / 24 Hours) * 33.333% of total revenue
\f6\i0 \
            hours_active = float(person["Metric_Weight"].split()[0])\
            coverage_pct = hours_active / 24.0\
            individual_payout = (coverage_pct * 0.33333) * monthly_ad_revenue\
            total_art_payout += individual_payout\
            \
        else:\
            individual_payout = 0.0\
            \
        if individual_payout > 0:\
            print(f"\uc0\u55357 \u56420  \{name\} (\{asset_type.upper()\}): Earnings Split: $\{individual_payout:.2f\}")\
\
    
\f7\i # 3. CONSOLIDATED PLATFORM SUMMARY REPORT
\f6\i0 \
    platform_retention = monthly_ad_revenue - (owner_guaranteed_share + total_art_payout + total_music_payout)\
    \
