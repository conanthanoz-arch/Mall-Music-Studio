\f0\b\fs42 \AppleTypeServices\AppleTypeServicesF2293774 \cf0 3. The Algorithmic Lead Arranger Code\
\pard\pardeftab560\slleading80\partightenfactor0

\f1\b0\fs32 \AppleTypeServices\AppleTypeServicesF2293774 \cf0 This module generates a 16-step sequence for your top-line melody. It uses a 
\f2\b \AppleTypeServices\AppleTypeServicesF2293774 Density Parameter
\f1\b0 \AppleTypeServices\AppleTypeServicesF2293774  (which you can control using your Tkinter UI slider) to determine how often a note plays, ensuring your background melodies remain subtle and relaxed.\
\pard\pardeftab560\slleading40\partightenfactor0

\f4\fs28\fsmilli14118 \AppleTypeServices \cf0 def generate_lofi_melody_lead(scale_midi_notes, density_percentage=70):\
    """\
    Generates a 16-step top-line melody loop that stays \
    harmonically locked within your defined scale array.\
    """\
    melody_sequence = []\
    current_note_idx = 0 
\f5\i # Start on the scale root fundamental note
\f4\i0 \
    \
    for step in range(16):\
        
\f5\i # 1. Respect your UI Slider Complexity Density setting
\f4\i0 \
        
\f5\i # If density is 60%, there is a 40% chance of a musical rest (silence)
\f4\i0 \
        if random.randint(1, 100) > density_percentage:\
            melody_sequence.append(0) 
\f5\i # Register a silent rest step
\f4\i0 \
            continue\
            \
        
\f5\i # 2. Prevent frantic note-spamming: restrict melody from hitting every single step
\f4\i0 \
        if step % 2 != 0 and random.random() < 0.60:\
            melody_sequence.append(0)\
            continue\
            \
        
\f5\i # 3. Calculate the next note using the Markov chain probability logic
\f4\i0 \
        current_note_idx = get_next_melodic_note(current_note_idx)\
        \
        
\f5\i # Pull the actual MIDI note value from your active aesthetic scale array
\f4\i0 \
        midi_note = scale_midi_notes[current_note_idx]\
        \
        
\f5\i # Add an octave shift to move the lead melody into Octave 4/5 (Higher register)
\f4\i0 \
        melody_sequence.append(midi_note + 24) \
        \
    return melody_sequence\
\pard\pardeftab560\slleading80\partightenfactor0

