\f4\fs28\fsmilli14118 \AppleTypeServices \cf0     def execute_test_generation(self):\
        
\f5\i # 1. Gather live parameters from your slider inputs
\f4\i0 \
        bpm = self.var_bpm.get()\
        density = self.var_melody_complexity.get()\
        \
        
\f5\i # 2. Baseline definitions for a C Major scale matrix
\f4\i0 \
        c_major_scale = [60, 62, 64, 65, 67, 69, 71] 
\f5\i # Middle C octave register
\f4\i0 \
        \
        
\f5\i # 3. Compute the algorithmic melody layout array
\f4\i0 \
        generated_lead = generate_lofi_melody_lead(c_major_scale, density_percentage=density)\
        \
        
\f5\i # 4. Print out a visual text matrix report to verify the layout instantly
\f4\i0 \
        print("\\n=== GENERATED MELODIC MAP SEQUENCE ===")\
        visual_steps = []\
        for note in generated_lead:\
            if note == 0:\
                visual_steps.append(" \uc0\u9472 \u9472  ") 
\f5\i # Text map symbol for a silent rest
\f4\i0 \
            else:\
                visual_steps.append(f"\uc0\u55356 \u57273 \{note\}") 
\f5\i # Displays the actual target MIDI note number
