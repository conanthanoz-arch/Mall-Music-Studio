\f4\i # F. Direct-To-RAM Pipe Streaming Execution
\f3\i0 \
        try:\
            
\f4\i # Writes raw compressed JPEG binary code straight into system standard out
\f3\i0 \
            final_img.save(sys.stdout.buffer, "JPEG", quality=85)\
        except IOError:\
            
\f4\i # Breaks loop cleanly if FFmpeg shuts down or drops connection
\f3\i0 \
            break\
\
        
\f4\i # G. CPU/Hardware Thermal Regulator Sleep Timer
\f3\i0 \
        elapsed_time = time.time() - start_time\
        if elapsed_time < target_frame_time:\
            time.sleep(target_frame_time - elapsed_time)\
            \
        frame += 1\
\
