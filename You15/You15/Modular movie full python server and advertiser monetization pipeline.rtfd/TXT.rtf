        cycle_frame = frame % TOTAL_FRAMES\
        \
        
\f4\i # A. Operations Shift / Closing Time Triggers
\f3\i0 \
        is_open = cycle_frame <= (4 * 60 * 60 * FRAME_RATE) 
\f4\i # Open first 4 hours
\f3\i0 \
        canvas = bg_day.copy() if is_open else bg_night.copy()\
\
        
\f4\i # B. Behavioral Security Guard Patrol State Machine
\f3\i0 \
        if direction == "right":\
            guard_x += guard_speed\
            sprite = guard_right\
            if guard_x > 1500: direction = "left"\
        else:\
            guard_x -= guard_speed\
            sprite = guard_left\
            if guard_x < 100: direction = "right"\
\
        
\f4\i # C. Zero-Latency Layer Compositing
