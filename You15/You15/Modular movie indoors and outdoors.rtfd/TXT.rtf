\f0\b\fs42 \AppleTypeServices\AppleTypeServicesF2293774 \cf0 3. Advanced Python Logic: Dual-Zone Lighting & Skylight Rays\
\pard\pardeftab560\slleading80\partightenfactor0

\f1\b0\fs32 \AppleTypeServices\AppleTypeServicesF2293774 \cf0 This advanced Python module calculates localized color temperatures. As the 6-hour time cycle progresses, it dims the indoor storefront lights while casting shifting sunlight angles through the skylights, and eventually turns on the outdoor sidewalk streetlights at night.\
\pard\pardeftab560\slleading40\partightenfactor0

\f3\fs28\fsmilli14118 \AppleTypeServices \cf0 import math\
from PIL import Image, ImageEnhance, ImageDraw\
\
def apply_advanced_environmental_lighting(canvas, cycle_frame, total_frames, guard_x):\
    
\f5\i # Create a lighting overlay canvas to paint our light rays onto
\f3\i0 \
    light_mask = Image.new("RGBA", canvas.size, (0, 0, 0, 0))\
    draw_light = ImageDraw.Draw(light_mask)\
    \
    
\f5\i # Calculate global time curve (0.0 = midnight, 1.0 = noon)
\f3\i0 \
    time_factor = (math.sin(2 * math.pi * cycle_frame / total_frames) + 1) / 2\
    is_night = time_factor < 0.3\
    \
    
\f5\i # --- PHASE A: SKYLIGHT SUN SHAFTS (Zone 1) ---
\f3\i0 \
    if time_factor > 0.3: 
\f5\i # Only draw sunbeams during day/sunset
\f3\i0 \
        
\f5\i # Calculate shifting sun ray angle based on the time of day
\f3\i0 \
        angle_offset = int(math.cos(2 * math.pi * cycle_frame / total_frames) * 150)\
        \
        
\f5\i # Draw a semi-transparent warm golden sun beam coming down from a skylight
\f3\i0 \
        
\f5\i # Skylight location: X=500 to X=700 on ceiling (Y=0) projecting down to the floor
\f3\i0 \
        sun_beam_opacity = int(time_factor * 80) 
\f5\i # Brightest at noon, fades at dusk
\f3\i0 \
        draw_light.polygon([\
            (500 + angle_offset, 0), (700 + angle_offset, 0), \
            (900 + angle_offset, 850), (600 + angle_offset, 850)\
        ], fill=(255, 230, 180, sun_beam_opacity))\
\
    
\f5\i # --- PHASE B: OUTDOOR STREETLIGHT CONE (Zone 2) ---
\f3\i0 \
    if is_night:\
        
\f5\i # If it's night, turn on the outdoor lamppost spotlight on the sidewalk
\f3\i0 \
        
\f5\i # Lamppost location: X=1650, Y=300 projecting down onto the sidewalk floor
\f3\i0 \
        draw_light.polygon([\
            (1650, 300), (1500, 850), (1800, 850)\
        ], fill=(255, 255, 200, 45)) 
\f5\i # Soft yellow ambient electric light
\f3\i0 \
\
    
\f5\i # --- PHASE C: DYNAMIC POSITION-BASED CHARACTER TINTING ---
\f3\i0 \
    
\f5\i # We slice out the section containing just the security guard to tint him accurately
\f3\i0 \
    
\f5\i # depending on whether he is currently standing inside or outside
\f3\i0 \
    if guard_x < 1400:\
        
\f5\i # GUARD IS INSIDE: Affected by warm interior lights and skylight rays
\f3\i0 \
        interior_brightness = 0.4 + (time_factor * 0.6)\
        
\f5\i # Apply interior color space values to canvas
\f3\i0 \
    else:\
        
\f5\i # GUARD IS OUTSIDE: Fully exposed to external natural sky colors
\f3\i0 \
        
\f5\i # At night, the sidewalk should look a cooler blue/slate color temperature
\f3\i0 \
        exterior_brightness = 0.2 + (time_factor * 0.8)\
        if is_night:\
            
\f5\i # Apply a cooler dark blue tint specifically to the sidewalk zone
\f3\i0 \
            sidewalk_overlay = Image.new("RGBA", (520, 1080), (15, 25, 55, 60))\
            canvas.paste(sidewalk_overlay, (1400, 0), sidewalk_overlay)\
\
    
\f5\i # Blend the lighting masks (sunbeams/streetlights) over the entire composition
\f3\i0 \
    canvas.alpha_composite(light_mask)\
    return canvas\
\pard\pardeftab560\slleading80\partightenfactor0

